<Window x:Class="Captura.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:interop="clr-namespace:System.Windows.Interop;assembly=PresentationCore"
        xmlns:local="clr-namespace:Captura"
        DataContext="{Binding MainViewModel, Source={StaticResource ServiceLocator}}"
        Title="CapturaEasy"
        Width="560"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Icon="../Images/Captura.ico"
        Left="{Binding Settings.UI.MainWindowLeft, Mode=TwoWay}"
        Top="{Binding Settings.UI.MainWindowTop, Mode=TwoWay}"
        BorderThickness="1"
        BorderBrush="{DynamicResource Accent}"
        Topmost="{Binding Settings.UI.MainWindowTopmost}">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="1"
                      UseAeroCaptionButtons="False"
                      NonClientFrameEdges="None"
                      CaptionHeight="0"/>
    </WindowChrome.WindowChrome>
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo Overlay="{Binding RecordingViewModel.RecorderState.Value, Source={StaticResource ServiceLocator}, Converter={StaticResource StateToTaskbarOverlayConverter}}"
                         Description="Captura">
            <TaskbarItemInfo.ThumbButtonInfos>
                <ThumbButtonInfo Command="{Binding ScreenShotViewModel.ScreenShotCommand, Source={StaticResource ServiceLocator}}"
                                 Description="{Binding ScreenShot, Source={StaticResource Loc}, Mode=OneWay}"
                                 DismissWhenClicked="True"
                                 ImageSource="{StaticResource ScreenShotImageSource}"/>
                <ThumbButtonInfo Command="{Binding RecordingViewModel.RecordCommand, Source={StaticResource ServiceLocator}}"
                                 Description="{Binding RecordStop, Source={StaticResource Loc}, Mode=OneWay}"
                                 DismissWhenClicked="True"
                                 ImageSource="{StaticResource RecordStopImageSource}"/>
            </TaskbarItemInfo.ThumbButtonInfos>
        </TaskbarItemInfo>
    </Window.TaskbarItemInfo>

    <Grid Background="{DynamicResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><!-- 顶栏 -->
            <RowDefinition Height="Auto"/><!-- 预倒计时大字（仅倒计时阶段可见） -->
            <RowDefinition Height="Auto"/><!-- 模式卡片 -->
            <RowDefinition Height="Auto"/><!-- Webcam 选择（仅 webcam 模式可见） -->
            <RowDefinition Height="Auto"/><!-- 场景/预设选择 -->
            <RowDefinition Height="Auto"/><!-- 音频 + 输出摘要 -->
            <RowDefinition Height="Auto"/><!-- 底栏主操作 -->
            <RowDefinition Height="Auto"/><!-- 预览宿主（可折叠） -->
        </Grid.RowDefinitions>

        <!-- NotifyIcon（托盘图标，不可见，承载右键菜单） -->
        <tb:TaskbarIcon x:Name="SystemTray" Grid.Row="0" Visibility="Collapsed"
                        IconSource="{Binding RecordingViewModel.RecorderState.Value, Source={StaticResource ServiceLocator}, Converter={StaticResource StateToTrayIconSourceConverter}}"
                        ToolTipText="Captura"
                        MenuActivation="RightClick"
                        LeftClickCommand="{Binding TrayLeftClickCommand}"
                        TrayMouseDoubleClick="SystemTray_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{Binding StartStopRecording, Source={StaticResource Loc}, Mode=OneWay}"
                              Command="{Binding RecordingViewModel.RecordCommand, Source={StaticResource ServiceLocator}}">
                        <MenuItem.Icon>
                            <Image Source="{StaticResource RecordStopImageSource}" Width="13" Margin="5"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{Binding PauseResumeRecording, Source={StaticResource Loc}, Mode=OneWay}"
                              Command="{Binding RecordingViewModel.PauseCommand, Source={StaticResource ServiceLocator}}">
                        <MenuItem.Icon>
                            <Image Width="10" Margin="5">
                                <Image.Source>
                                    <DrawingImage>
                                        <DrawingImage.Drawing>
                                            <GeometryDrawing Geometry="{Binding Icons.Pause, Source={StaticResource ServiceLocator}}"
                                                             Brush="{DynamicResource ItemText}"/>
                                        </DrawingImage.Drawing>
                                    </DrawingImage>
                                </Image.Source>
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RecordingViewModel.RecorderState.Value, Source={StaticResource ServiceLocator}}" Value="Paused">
                                                <Setter Property="LayoutTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="90"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="{Binding ScreenShot, Source={StaticResource Loc}, Mode=OneWay}"
                              Command="{Binding ScreenShotViewModel.ScreenShotCommand, Source={StaticResource ServiceLocator}}">
                        <MenuItem.Icon>
                            <Image Source="{StaticResource ScreenShotImageSource}" Width="13" Margin="5"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{Binding ScreenShotDesktop, Source={StaticResource Loc}, Mode=OneWay}"
                              Command="{Binding ScreenShotViewModel.ScreenShotDesktopCommand, Source={StaticResource ServiceLocator}}">
                        <MenuItem.Icon>
                            <Image Source="{StaticResource ScreenShotImageSource}" Width="13" Margin="5"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="ScreenShot (Region)"
                              Command="{Binding ScreenShotViewModel.ScreenshotRegionCommand, Source={StaticResource ServiceLocator}}">
                        <MenuItem.Icon>
                            <Image Width="13" Margin="5">
                                <Image.Source>
                                    <DrawingImage>
                                        <DrawingImage.Drawing>
                                            <GeometryDrawing Geometry="{Binding Icons.Crop, Source={StaticResource ServiceLocator}}"
                                                             Brush="{DynamicResource ItemText}"/>
                                        </DrawingImage.Drawing>
                                    </DrawingImage>
                                </Image.Source>
                            </Image>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="ScreenShot (Screen)"
                              Command="{Binding ScreenShotViewModel.ScreenshotScreenCommand, Source={StaticResource ServiceLocator}}">
                        <MenuItem.Icon>
                            <Image Width="13" Margin="5">
                                <Image.Source>
                                    <DrawingImage>
                                        <DrawingImage.Drawing>
                                            <GeometryDrawing Geometry="{Binding Icons.Screen, Source={StaticResource ServiceLocator}}"
                                                             Brush="{DynamicResource ItemText}"/>
                                        </DrawingImage.Drawing>
                                    </DrawingImage>
                                </Image.Source>
                            </Image>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="ScreenShot (Window)"
                              Command="{Binding ScreenShotViewModel.ScreenshotWindowCommand, Source={StaticResource ServiceLocator}}">
                        <MenuItem.Icon>
                            <Image Width="13" Margin="5">
                                <Image.Source>
                                    <DrawingImage>
                                        <DrawingImage.Drawing>
                                            <GeometryDrawing Geometry="{Binding Icons.Window, Source={StaticResource ServiceLocator}}"
                                                             Brush="{DynamicResource ItemText}"/>
                                        </DrawingImage.Drawing>
                                    </DrawingImage>
                                </Image.Source>
                            </Image>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Show Main Window" Click="ShowMainWindow">
                        <MenuItem.Icon>
                            <Image Width="13" Margin="5">
                                <Image.Source>
                                    <DrawingImage>
                                        <DrawingImage.Drawing>
                                            <GeometryDrawing Geometry="{Binding Icons.Window, Source={StaticResource ServiceLocator}}"
                                                             Brush="{DynamicResource ItemText}"/>
                                        </DrawingImage.Drawing>
                                    </DrawingImage>
                                </Image.Source>
                            </Image>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{Binding Exit, Source={StaticResource Loc}, Mode=OneWay}" Click="MenuExit_Click">
                        <MenuItem.Icon>
                            <Image Width="13" Margin="5">
                                <Image.Source>
                                    <DrawingImage>
                                        <DrawingImage.Drawing>
                                            <GeometryDrawing Geometry="{Binding Icons.Close, Source={StaticResource ServiceLocator}}"
                                                             Brush="#b71c1c"/>
                                        </DrawingImage.Drawing>
                                    </DrawingImage>
                                </Image.Source>
                            </Image>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- ============ 顶栏：状态区 + 窗口控制 ============ -->
        <Grid Grid.Row="0" Height="40"
              Background="{DynamicResource ButtonBackgroundHover}"
              MouseLeftButtonDown="TopBar_PreviewMouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        Margin="12,0" VerticalAlignment="Center">
                <Ellipse Width="9" Height="9" Margin="0,0,8,0" Fill="#ee2c2c">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RecordingViewModel.RecorderState.Value, Source={StaticResource ServiceLocator}}" Value="Recording">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1" To="0.25" Duration="0:0:0.8" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RecordingViewModel.RecorderState.Value, Source={StaticResource ServiceLocator}}" Value="Paused">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold"
                           FontFamily="{StaticResource BrandFont}" FontSize="15">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="CapturaEasy"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RecordingViewModel.RecorderState.Value, Source={StaticResource ServiceLocator}}" Value="Recording">
                                    <Setter Property="Text" Value="录制中"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RecordingViewModel.RecorderState.Value, Source={StaticResource ServiceLocator}}" Value="Paused">
                                    <Setter Property="Text" Value="已暂停"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding TimerModel.TimeSpan, Source={StaticResource ServiceLocator}, StringFormat=mm\\:ss}"
                           FontSize="16" FontFamily="Consolas"
                           Foreground="{DynamicResource Accent}"
                           Visibility="{Binding ViewConditions.FpsVisibility.Value, Source={StaticResource ServiceLocator}}"/>
                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.6"
                           Visibility="{Binding ViewConditions.FpsVisibility.Value, Source={StaticResource ServiceLocator}}">
                    <Run Text="FPS:"/><Run Text="{Binding FpsManager.Fps, Source={StaticResource ServiceLocator}, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>

            <local:ModernButton Grid.Column="2" ToolTip="设置"
                                IconData="{Binding Icons.Settings, Source={StaticResource ServiceLocator}}"
                                Click="OpenSettings"/>
            <local:ModernButton Grid.Column="3" ToolTip="最小化"
                                IconData="{Binding Icons.Minimize, Source={StaticResource ServiceLocator}}"
                                Click="MinButton_Click"/>
            <local:ModernButton Grid.Column="4" ToolTip="关闭"
                                Foreground="#77ef5350"
                                IconData="{Binding Icons.Close, Source={StaticResource ServiceLocator}}"
                                Click="CloseButton_Click"/>
        </Grid>

        <!-- ============ 预倒计时大字（仅预倒计时阶段可见） ============ -->
        <Grid Grid.Row="1" Height="120"
              Background="{DynamicResource Accent}"
              Visibility="{Binding TimerModel.Waiting, Source={StaticResource ServiceLocator}, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="72" FontWeight="Bold" Foreground="White"
                       Text="{Binding TimerModel.Countdown, Source={StaticResource ServiceLocator}}"/>
        </Grid>

        <!-- ============ 模式选择卡片 2×2 ============ -->
        <ListBox Grid.Row="2" Margin="16,16,16,8"
                 ItemsSource="{Binding VideoSourcesViewModel.VideoSources, Source={StaticResource ServiceLocator}}"
                 SelectedValue="{Binding VideoSourcesViewModel.SelectedVideoSourceKind, Mode=TwoWay, Delay=10, Source={StaticResource ServiceLocator}}"
                 IsEnabled="{Binding ViewConditions.IsEnabled.Value, Source={StaticResource ServiceLocator}}"
                 Background="Transparent" BorderThickness="0"
                 SelectionMode="Single">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="4"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="CardBorder"
                                        CornerRadius="6"
                                        BorderThickness="2"
                                        BorderBrush="Transparent"
                                        Background="{DynamicResource ButtonBackgroundHover}"
                                        Padding="14,12">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{Binding Icon}"
                                              Width="26" Height="26"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Fill="{DynamicResource ItemText}"
                                              Margin="0,0,12,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Opacity="0.55" FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="170"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                        <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource Accent}"/>
                                        <Setter Property="TextElement.Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- ============ Webcam 选择（仅 webcam 模式可见） ============ -->
        <DockPanel Grid.Row="3" Margin="16,4"
                   Visibility="{Binding ViewConditions.IsWebcamMode.Value, Source={StaticResource ServiceLocator}, Converter={StaticResource BoolToVisibilityConverter}}">
            <Label Content="摄像头:" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding WebcamModel.AvailableCams, Source={StaticResource ServiceLocator}}"
                      SelectedItem="{Binding WebcamModel.SelectedCam, Mode=TwoWay, Source={StaticResource ServiceLocator}}"
                      IsEnabled="{Binding ViewConditions.CanChangeWebcam.Value, Source={StaticResource ServiceLocator}}"
                      DisplayMemberPath="Name"/>
        </DockPanel>

        <!-- ============ 场景/预设选择 ============ -->
        <Grid Grid.Row="4" Margin="16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="场景" VerticalAlignment="Center" FontSize="12"
                       Foreground="{DynamicResource ItemText}" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="1" x:Name="SceneComboBox"
                      ItemsSource="{Binding SceneViewModel.Scenes, Source={StaticResource ServiceLocator}}"
                      DisplayMemberPath="Name"
                      SelectedItem="{Binding SceneViewModel.SelectedScene.Value, Source={StaticResource ServiceLocator}, Mode=TwoWay}"
                      ToolTip="选择场景一键切换录制配置" Margin="0,0,8,0"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <local:ModernButton IconData="{Binding Icons.NewFile, Source={StaticResource ServiceLocator}}"
                                    ToolTip="将当前配置保存为场景" Click="SaveScene_Click" Margin="0,0,4,0"/>
                <local:ModernButton IconData="{Binding Icons.Delete, Source={StaticResource ServiceLocator}}"
                                    ToolTip="删除选中场景"
                                    Command="{Binding SceneViewModel.DeleteCommand, Source={StaticResource ServiceLocator}}"
                                    CommandParameter="{Binding SelectedItem, ElementName=SceneComboBox}"/>
            </StackPanel>
        </Grid>

        <!-- ============ 音频快切 + 输出摘要 ============ -->
        <Grid Grid.Row="5" Margin="16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border CornerRadius="14" Padding="10,6" Margin="0,0,8,0"
                        BorderThickness="1" BorderBrush="{DynamicResource ModernButtonBorder}">
                    <local:ModernToggleButton IconData="{Binding Icons.Mic, Source={StaticResource ServiceLocator}}"
                                              IsChecked="{Binding Settings.Audio.RecordMicrophone, Mode=TwoWay}" ToolTip="麦克风"/>
                </Border>
                <Border CornerRadius="14" Padding="10,6"
                        BorderThickness="1" BorderBrush="{DynamicResource ModernButtonBorder}">
                    <local:ModernToggleButton IconData="{Binding Icons.Speaker, Source={StaticResource ServiceLocator}}"
                                              IsChecked="{Binding Settings.Audio.RecordSpeaker, Mode=TwoWay}" ToolTip="系统声音"/>
                </Border>
            </StackPanel>
            <Border Grid.Column="2" CornerRadius="14" Padding="12,6"
                    Background="{DynamicResource ButtonBackgroundHover}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{Binding Icons.VideoFile, Source={StaticResource ServiceLocator}}"
                          Width="13" Height="13" Stretch="Uniform"
                          Fill="{DynamicResource ItemText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock VerticalAlignment="Center" FontSize="11">
                        <Run Text="{Binding VideoWritersViewModel.SelectedVideoWriter, Mode=OneWay, Source={StaticResource ServiceLocator}}"/> ·
                        <Run Text="{Binding Settings.Video.FrameRate, Mode=OneWay}"/>fps ·
                        <Run Text="{Binding Settings.Video.Quality, Mode=OneWay, StringFormat={}{0:N0}%}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============ 底栏主操作 ============ -->
        <Grid Grid.Row="6" Margin="16,12,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Height="44"
                    Command="{Binding RecordingViewModel.RecordCommand, Source={StaticResource ServiceLocator}}"
                    IsEnabled="{Binding ViewConditions.IsEnabled.Value, Source={StaticResource ServiceLocator}}"
                    Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Content">
                            <Setter.Value>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Width="14" Height="14" Stretch="Uniform" Fill="White" Margin="0,0,8,0"
                                          Data="{Binding Icons.Record, Source={StaticResource ServiceLocator}}" VerticalAlignment="Center"/>
                                    <TextBlock Text="开始录制" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RecordingViewModel.RecorderState.Value, Source={StaticResource ServiceLocator}}" Value="Recording">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Width="14" Height="14" Stretch="Uniform" Fill="White" Margin="0,0,8,0"
                                                  Data="{Binding Icons.Stop, Source={StaticResource ServiceLocator}}" VerticalAlignment="Center"/>
                                            <TextBlock Text="停止录制" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Grid Grid.Column="1" Margin="0,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Height="44" Width="60"
                        Command="{Binding ScreenShotViewModel.ScreenShotCommand, Source={StaticResource ServiceLocator}}" ToolTip="截图（当前源）">
                    <Path Width="18" Height="18" Stretch="Uniform" Fill="White"
                          Data="{Binding Icons.Camera, Source={StaticResource ServiceLocator}}"/>
                </Button>
                <Button Grid.Column="1" x:Name="ShotDropDown" Height="44" Width="22"
                        Click="ToggleShotFlyout" ToolTip="更多截图方式">
                    <Path Width="8" Height="8" Stretch="Uniform" Data="M7,10L12,15L17,10H7Z" Fill="{DynamicResource ItemText}"/>
                </Button>
                <Popup x:Name="ShotFlyout" PlacementTarget="{Binding ElementName=ShotDropDown}"
                       Placement="Top" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ModernButtonBorder}"
                            BorderThickness="1" CornerRadius="6" Padding="4">
                        <StackPanel MinWidth="180">
                            <Button Command="{Binding ScreenShotViewModel.ScreenshotRegionCommand, Source={StaticResource ServiceLocator}}"
                                    PreviewMouseLeftButtonUp="ShotItem_Click"
                                    Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="10,8" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"
                                          Data="{Binding Icons.Crop, Source={StaticResource ServiceLocator}}" Fill="{DynamicResource ItemText}"/>
                                    <TextBlock Text="区域截图" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ScreenShotViewModel.ScreenshotScreenCommand, Source={StaticResource ServiceLocator}}"
                                    PreviewMouseLeftButtonUp="ShotItem_Click"
                                    Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="10,8" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"
                                          Data="{Binding Icons.Screen, Source={StaticResource ServiceLocator}}" Fill="{DynamicResource ItemText}"/>
                                    <TextBlock Text="屏幕截图" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ScreenShotViewModel.ScreenshotWindowCommand, Source={StaticResource ServiceLocator}}"
                                    PreviewMouseLeftButtonUp="ShotItem_Click"
                                    Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="10,8" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"
                                          Data="{Binding Icons.Window, Source={StaticResource ServiceLocator}}" Fill="{DynamicResource ItemText}"/>
                                    <TextBlock Text="窗口截图" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ScreenShotViewModel.ScreenShotDesktopCommand, Source={StaticResource ServiceLocator}}"
                                    PreviewMouseLeftButtonUp="ShotItem_Click"
                                    Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="10,8" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="15" Height="15" Stretch="Uniform" Margin="0,0,10,0"
                                          Data="{Binding Icons.Screen, Source={StaticResource ServiceLocator}}" Fill="{DynamicResource ItemText}"/>
                                    <TextBlock Text="全屏截图" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
            <Button Grid.Column="2" Height="44" Width="44" Click="ToggleRecent" ToolTip="最近录制">
                <Path Width="18" Height="18" Stretch="Uniform"
                      Data="{Binding Icons.History, Source={StaticResource ServiceLocator}}" Fill="{DynamicResource ItemText}"/>
            </Button>
        </Grid>

        <!-- ============ 预览宿主（可折叠，供 PreviewWindowService 使用） ============ -->
        <Expander Grid.Row="7" Header="Preview"
                  IsExpanded="{Binding Settings.UI.Expanded}"
                  Margin="16,0,16,12"
                  Visibility="{Binding Settings.UI.Expanded, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Height="200">
                <Label Content="Preview" HorizontalAlignment="Center" Opacity="0.7"/>
                <WindowsFormsHost x:Name="WinFormsHost" Visibility="Collapsed">
                    <wf:PictureBox x:Name="DisplayImage" SizeMode="Zoom"/>
                </WindowsFormsHost>
                <Image>
                    <Image.Source>
                        <interop:D3DImage x:Name="D3DImage"/>
                    </Image.Source>
                </Image>
            </Grid>
        </Expander>
    </Grid>
</Window>
