<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        CapturaBridge.xaml — 暗色版
        将 ModernUI 时代散布在 ~20 个 XAML 中的资源键名重定义为暗色调色板。
        现有 XAML 引用 DynamicResource ItemText / Accent / WindowBackground 等无需修改。
        这些值通过 MaterialDesign 主题切换在代码后置（ThemeService）中整体替换。
    -->

    <!-- 窗口/面板背景：Material Grey 900 (#212121) -->
    <Color x:Key="WindowBackgroundColor" A="255" R="33" G="33" B="33"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FF212121"/>
    <SolidColorBrush x:Key="WindowBackgroundAlt" Color="#FF303030"/>

    <!-- 窗口文字：白色 87% 不透明 -->
    <SolidColorBrush x:Key="WindowText" Color="#DEFFFFFF"/>
    <SolidColorBrush x:Key="WindowTextSecondary" Color="#99FFFFFF"/>

    <!-- 列表项/卡片背景：Material Grey 800 (#424242) -->
    <SolidColorBrush x:Key="ItemBackground" Color="#FF424242"/>
    <SolidColorBrush x:Key="ItemBackgroundAlt" Color="#FF424242"/>
    <SolidColorBrush x:Key="ItemBorder" Color="#FF555555"/>
    <SolidColorBrush x:Key="ItemText" Color="#DEFFFFFF"/>

    <!-- 强调色：Material Deep Purple 500 (#6200EA) -->
    <Color x:Key="AccentColor" A="255" R="98" G="0" B="234"/>
    <SolidColorBrush x:Key="Accent" Color="#FF6200EA"/>
    <SolidColorBrush x:Key="AccentAlt" Color="#FF3700B3"/>

    <!-- 按钮三态 -->
    <SolidColorBrush x:Key="ModernButtonText" Color="#DEFFFFFF"/>
    <SolidColorBrush x:Key="ModernButtonTextHover" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ModernButtonTextDisabled" Color="#61FFFFFF"/>
    <SolidColorBrush x:Key="ModernButtonBorder" Color="#FF555555"/>
    <SolidColorBrush x:Key="ButtonBackgroundHover" Color="#FF505050"/>
    <SolidColorBrush x:Key="ButtonText" Color="#DEFFFFFF"/>
    <SolidColorBrush x:Key="ButtonTextDisabled" Color="#61FFFFFF"/>

    <!-- 链接 -->
    <SolidColorBrush x:Key="LinkText" Color="#FF6200EA"/>
    <SolidColorBrush x:Key="LinkButtonText" Color="#FF6200EA"/>

    <!-- 区域分割 -->
    <SolidColorBrush x:Key="RegionBorder" Color="#FF555555"/>

</ResourceDictionary>
