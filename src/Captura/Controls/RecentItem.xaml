<UserControl x:Class="Captura.RecentItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Captura.Models;assembly=Captura.Core"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance models:FileRecentItem}">
    <!-- 卡片容器：圆角 + hover 高亮（用 ModernUI 的 ItemBackground / ItemBorder） -->
    <Border Background="{DynamicResource ItemBackground}"
            BorderBrush="{DynamicResource ItemBorder}"
            BorderThickness="1"
            CornerRadius="4"
            Margin="0,3"
            Padding="8">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <!-- hover 时把背景透明度降低，模拟高亮 -->
                        <Setter Property="Opacity" Value="0.85"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <DockPanel IsEnabled="{Binding IsSaving, Converter={StaticResource NegatingConverter}}">

            <!-- 缩略图区：有图显示 Image，无图显示图标占位 -->
            <Grid Width="56"
                  Height="42"
                  Margin="0,0,10,0">
                <!-- 有缩略图时显示 -->
                <Image Source="{Binding ThumbnailPath, UpdateSourceTrigger=PropertyChanged}"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ThumbnailPath}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- 无缩略图时显示文件类型图标占位 -->
                <Path Stretch="Uniform"
                      Height="20"
                      Width="20"
                      Data="{Binding Icon}"
                      Fill="{Binding IconColor}">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ThumbnailPath}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
            </Grid>

            <Button DockPanel.Dock="Right"
                    ToolTip="{Binding RemoveFromList, Source={StaticResource Loc}, Mode=OneWay}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Margin="5,0"
                    VerticalAlignment="Center"
                    Command="{Binding RemoveCommand}">
                <Path Stretch="UniformToFill"
                      Height="10"
                      Width="10"
                      Data="{Binding Icons.Close, Source={StaticResource ServiceLocator}}"/>
            </Button>

            <!-- 中间：文件名 + 右键菜单 -->
            <Button Content="{Binding Display}"
                    BorderThickness="0"
                    Background="Transparent"
                    HorizontalContentAlignment="Left"
                    VerticalAlignment="Center"
                    Command="{Binding ClickCommand}">
                <Button.ContextMenu>
                    <ContextMenu ItemsSource="{Binding Actions}">
                        <ContextMenu.ItemContainerStyle>
                            <Style>
                                <Setter Property="MenuItem.HeaderTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <DockPanel>
                                                <Path Data="{Binding Icon}"
                                                      Width="15"
                                                      Height="15"
                                                      Margin="0,0,10,0"
                                                      Stretch="Uniform"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>

                                                <TextBlock Text="{Binding Name}"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="MenuItem.Command" Value="{Binding ClickCommand}"/>
                            </Style>
                        </ContextMenu.ItemContainerStyle>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

        </DockPanel>
    </Border>
</UserControl>
